---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const projects = await getCollection('portfolio', ({ data }) => !data.draft);
const tags = [...new Set(projects.flatMap((project) => project.data.tags))].sort((a, b) => a.localeCompare(b));
---

<BaseLayout title="Portfolio" description="Project case studies">
  <h1>Portfolio</h1>
  <input id="project-search" type="search" placeholder="Search projects..." autocomplete="off" />
  <div class="chips">
    <button class="chip active" type="button" data-filter="all">All</button>
    {tags.map((tag) => (
      <button class="chip" type="button" data-filter={tag.toLowerCase()}>{tag}</button>
    ))}
  </div>
  <div class="list">
    {projects.map((project) => (
      <article class="card filter-item" data-tags={project.data.tags.map((tag) => tag.toLowerCase()).join(',')} data-search={`${project.data.title} ${project.data.description || ''} ${project.data.tags.join(' ')} ${project.data.stack.join(' ')}`}>
        <h2><a href={`${base}portfolio/${project.slug}/`}>{project.data.title}</a></h2>
        <p>{project.data.description}</p>
        <p class="meta">Stack: {project.data.stack.join(', ')}</p>
      </article>
    ))}
  </div>

  <script is:inline>
    const search = document.getElementById('project-search');
    const chips = Array.from(document.querySelectorAll('.chip'));
    const items = Array.from(document.querySelectorAll('.filter-item'));
    let activeTag = 'all';

    function render() {
      const query = (search?.value || '').toLowerCase();
      items.forEach((item) => {
        const text = (item.dataset.search || '').toLowerCase();
        const tags = (item.dataset.tags || '').split(',').filter(Boolean);
        const tagMatch = activeTag === 'all' || tags.includes(activeTag);
        const searchMatch = !query || text.includes(query);
        item.style.display = tagMatch && searchMatch ? '' : 'none';
      });
    }

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        activeTag = chip.dataset.filter || 'all';
        chips.forEach((c) => c.classList.toggle('active', c === chip));
        render();
      });
    });

    search?.addEventListener('input', render);
  </script>
</BaseLayout>
