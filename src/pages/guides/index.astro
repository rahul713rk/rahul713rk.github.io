---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { slugify } from '../../utils/slugify';

const base = import.meta.env.BASE_URL;

const pages = await getCollection('guides', ({ data }) => !data.draft);
const sorted = pages.sort((a, b) => a.data.guide.localeCompare(b.data.guide) || a.data.order - b.data.order);
const tags = [...new Set(sorted.flatMap((page) => page.data.tags))].sort((a, b) => a.localeCompare(b));
---

<BaseLayout title="Guides" description="Step-by-step guides">
  <h1>Guides</h1>
  <input id="guide-search" type="search" placeholder="Search guide pages..." autocomplete="off" />
  <div class="chips">
    <button class="chip active" type="button" data-filter="all">All</button>
    {tags.map((tag) => (
      <button class="chip" type="button" data-filter={slugify(tag)}>{tag}</button>
    ))}
  </div>
  <div class="list">
    {sorted.map((page) => (
      <article class="card filter-item" data-tags={page.data.tags.map((tag) => slugify(tag)).join(',')} data-search={`${page.data.guide} ${page.data.title} ${page.data.description || ''} ${page.data.tags.join(' ')}`}>
        <h2><a href={`${base}guides/${page.slug}/`}>{page.data.guide}: {page.data.title}</a></h2>
        <p>{page.data.description}</p>
        <p class="meta">Step {page.data.order}</p>
      </article>
    ))}
  </div>

  <script is:inline>
    const search = document.getElementById('guide-search');
    const chips = Array.from(document.querySelectorAll('.chip'));
    const items = Array.from(document.querySelectorAll('.filter-item'));
    let activeTag = 'all';

    function render() {
      const query = (search?.value || '').toLowerCase();
      items.forEach((item) => {
        const text = (item.dataset.search || '').toLowerCase();
        const tags = (item.dataset.tags || '').split(',').filter(Boolean);
        const tagMatch = activeTag === 'all' || tags.includes(activeTag);
        const searchMatch = !query || text.includes(query);
        item.style.display = tagMatch && searchMatch ? '' : 'none';
      });
    }

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        activeTag = chip.dataset.filter || 'all';
        chips.forEach((c) => c.classList.toggle('active', c === chip));
        render();
      });
    });

    search?.addEventListener('input', render);
  </script>
</BaseLayout>
