---
import BaseLayout from './BaseLayout.astro';
import { slugify } from '../utils/slugify';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  guide: string;
  order: number;
  tags?: string[];
  readingTime?: number;
  headings?: Heading[];
}

const { title, description, guide, order, tags = [], readingTime, headings = [] } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description} type="article">
  <article class="content-grid">
    <div>
      <p class="eyebrow">Guide: {guide} / Step {order}</p>
      <h1>{title}</h1>
      <p class="meta">
        {readingTime && <span>{readingTime} min read</span>}
      </p>
      <p class="tags">
        {tags.map((tag) => <a href={`${base}tags/${slugify(tag)}/`}>#{tag}</a>)}
      </p>
      <slot />
    </div>

    {headings.length > 1 && (
      <aside class="toc">
        <h2>Contents</h2>
        <ul>
          {headings
            .filter((item) => item.depth <= 3)
            .map((item) => (
              <li><a href={`#${item.slug}`}>{item.text}</a></li>
            ))}
        </ul>
      </aside>
    )}
  </article>
</BaseLayout>
